{{- define "mise_structured_tools" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- $distro_codename := index . "distro_codename" -}}
{{- range index . "tools" }}
{{- if and (not (kindIs "string" .)) (get . "variants") }}
{{- $base := deepCopy . -}}
{{- $_ := unset $base "variants" -}}
{{- range get . "variants" }}
{{- template "mise_structured_tool" dict "tool" (mergeOverwrite (deepCopy $base) .) "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- else }}
{{- template "mise_structured_tool" dict "tool" . "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- end }}
{{- end -}}
{{- $environment := "local" -}}
{{- if .codespaces -}}
{{- $environment = "codespace" -}}
{{- else if eq (env "DEVCONTAINER") "true" -}}
{{- $environment = "devcontainer" -}}
{{- end -}}
{{- $distro_codename := env "MISE_DISTRO_CODENAME" -}}
{{- if and (not $distro_codename) (eq .chezmoi.os "linux") -}}
{{- $distro_codename = output "sh" "-c" "sed -n 's/^VERSION_CODENAME=//p' /etc/os-release 2>/dev/null | tr -d '\"' | head -n1" | trim -}}
{{- end -}}
[tool_alias]
{{ template "mise_aliases" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo "distro_codename" $distro_codename }}

[tools]
# === Filtered mise tools (from .chezmoidata.yaml) ===
{{ template "mise_plain_tools" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo "distro_codename" $distro_codename }}
{{ template "mise_structured_tools" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo "distro_codename" $distro_codename }}
[settings]
idiomatic_version_file_enable_tools = ["node"]
