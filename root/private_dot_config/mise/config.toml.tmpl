{{- define "mise_plain_tool" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- $distro_codename := index . "distro_codename" -}}
{{- $tool := index . "tool" -}}
{{- if kindIs "string" $tool }}
{{ $tool | quote }} = "latest"
{{- else if not (get $tool "variants") }}
{{- $matches := true -}}
{{- $filters := get $tool "filters" -}}
{{- if $filters }}
{{- $tool_os := get $filters "os" -}}
{{- if and $tool_os (not (has $os $tool_os)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_environments := get $filters "environment" -}}
{{- if and $tool_environments (not (has $environment $tool_environments)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_distro_codenames := get $filters "distro_codename" -}}
{{- if and $tool_distro_codenames (not (has $distro_codename $tool_distro_codenames)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_not_distro_codenames := get $filters "not_distro_codename" -}}
{{- if and $tool_not_distro_codenames (has $distro_codename $tool_not_distro_codenames) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_repos := get $filters "repo" -}}
{{- if $tool_repos }}
{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
{{- $repo_matched = or $repo_matched (eq $pattern $repo) -}}
{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (not (or (get $tool "asset_pattern") (get $tool "bin") (get $tool "bin_path"))) }}
{{ get $tool "name" | quote }} = {{ default "latest" (get $tool "version") | quote }}
{{- end }}
{{- end }}
{{- end -}}
{{- define "mise_plain_tools" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- $distro_codename := index . "distro_codename" -}}
{{- range index . "tools" }}
{{- if and (not (kindIs "string" .)) (get . "variants") }}
{{- $base := deepCopy . -}}
{{- $_ := unset $base "variants" -}}
{{- range get . "variants" }}
{{- template "mise_plain_tool" dict "tool" (mergeOverwrite (deepCopy $base) .) "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- else }}
{{- template "mise_plain_tool" dict "tool" . "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- end }}
{{- end -}}
{{- define "mise_alias" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- $distro_codename := index . "distro_codename" -}}
{{- $tool := index . "tool" -}}
{{- if and (not (kindIs "string" $tool)) (not (get $tool "variants")) }}
{{- $matches := true -}}
{{- $filters := get $tool "filters" -}}
{{- if $filters }}
{{- $tool_os := get $filters "os" -}}
{{- if and $tool_os (not (has $os $tool_os)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_environments := get $filters "environment" -}}
{{- if and $tool_environments (not (has $environment $tool_environments)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_distro_codenames := get $filters "distro_codename" -}}
{{- if and $tool_distro_codenames (not (has $distro_codename $tool_distro_codenames)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_not_distro_codenames := get $filters "not_distro_codename" -}}
{{- if and $tool_not_distro_codenames (has $distro_codename $tool_not_distro_codenames) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_repos := get $filters "repo" -}}
{{- if $tool_repos }}
{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
{{- $repo_matched = or $repo_matched (eq $pattern $repo) -}}
{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (get $tool "alias") }}
{{ get $tool "name" | quote }} = {{ get $tool "alias" | quote }}
{{- end }}
{{- end }}
{{- end -}}
{{- define "mise_aliases" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- $distro_codename := index . "distro_codename" -}}
{{- range index . "tools" }}
{{- if and (not (kindIs "string" .)) (get . "variants") }}
{{- $base := deepCopy . -}}
{{- $_ := unset $base "variants" -}}
{{- range get . "variants" }}
{{- template "mise_alias" dict "tool" (mergeOverwrite (deepCopy $base) .) "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- else }}
{{- template "mise_alias" dict "tool" . "environment" $environment "os" $os "repo" $repo "distro_codename" $distro_codename }}
{{- end }}
{{- end }}
