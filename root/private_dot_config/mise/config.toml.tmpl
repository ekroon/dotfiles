{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
