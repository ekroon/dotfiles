{{- define "mise_plain_tools" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- range index . "tools" }}
{{- if kindIs "string" . }}
{{ . | quote }} = "latest"
{{- else }}
{{- $matches := true -}}
{{- $filters := get . "filters" -}}
{{- if $filters }}
{{- $tool_os := get $filters "os" -}}
{{- if and $tool_os (not (has $os $tool_os)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_environments := get $filters "environment" -}}
{{- if and $tool_environments (not (has $environment $tool_environments)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_repos := get $filters "repo" -}}
{{- if $tool_repos }}
{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
{{- $repo_matched = or $repo_matched (eq $pattern $repo) -}}
{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (not (or (get . "asset_pattern") (get . "bin_path"))) }}
{{ get . "name" | quote }} = {{ default "latest" (get . "version") | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end -}}
{{- define "mise_aliases" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- range index . "tools" }}
{{- if not (kindIs "string" .) }}
{{- $matches := true -}}
{{- $filters := get . "filters" -}}
{{- if $filters }}
{{- $tool_os := get $filters "os" -}}
{{- if and $tool_os (not (has $os $tool_os)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_environments := get $filters "environment" -}}
{{- if and $tool_environments (not (has $environment $tool_environments)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_repos := get $filters "repo" -}}
{{- if $tool_repos }}
{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
{{- $repo_matched = or $repo_matched (eq $pattern $repo) -}}
{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (get . "alias") }}
{{ get . "name" | quote }} = {{ get . "alias" | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end -}}
{{- define "mise_structured_tools" -}}
{{- $environment := index . "environment" -}}
{{- $os := index . "os" -}}
{{- $repo := index . "repo" -}}
{{- range index . "tools" }}
{{- if not (kindIs "string" .) }}
{{- $matches := true -}}
{{- $asset_pattern := get . "asset_pattern" -}}
{{- $bin_path := get . "bin_path" -}}
{{- $filters := get . "filters" -}}
{{- if $filters }}
{{- $tool_os := get $filters "os" -}}
{{- if and $tool_os (not (has $os $tool_os)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_environments := get $filters "environment" -}}
{{- if and $tool_environments (not (has $environment $tool_environments)) }}
{{- $matches = false -}}
{{- end }}
{{- $tool_repos := get $filters "repo" -}}
{{- if $tool_repos }}
{{- $repo_matched := false -}}
{{- range $tool_repos }}
{{- $pattern := . -}}
{{- if eq $pattern "*" -}}
{{- $repo_matched = true -}}
{{- else if hasSuffix "/*" $pattern -}}
{{- $repo_matched = or $repo_matched (hasPrefix (trimSuffix "*" $pattern) $repo) -}}
{{- else -}}
{{- $repo_matched = or $repo_matched (eq $pattern $repo) -}}
{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (or $asset_pattern $bin_path) }}

[tools.{{ get . "name" | quote }}]
version = {{ default "latest" (get . "version") | quote }}
{{- if $asset_pattern }}
asset_pattern = {{ $asset_pattern | quote }}
{{- end }}
{{- if $bin_path }}
bin_path = {{ $bin_path | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end -}}
{{- $environment := "local" -}}
{{- if .codespaces -}}
{{- $environment = "codespace" -}}
{{- else if eq (env "DEVCONTAINER") "true" -}}
{{- $environment = "devcontainer" -}}
{{- end -}}
[tool_alias]
{{ template "mise_aliases" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo }}

[tools]
# === Filtered mise tools (from .chezmoidata.yaml) ===
{{ template "mise_plain_tools" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo }}
{{ template "mise_structured_tools" dict "tools" .mise_tools "environment" $environment "os" .chezmoi.os "repo" .repo }}
[settings]
idiomatic_version_file_enable_tools = ["node"]
