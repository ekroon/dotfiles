{{- end -}}
{{- end }}
{{- if not $repo_matched }}
{{- $matches = false -}}
{{- end }}
{{- end }}
{{- end }}
{{- if and $matches (or $asset_pattern $bin $bin_path) }}

[tools.{{ get $tool "name" | quote }}]
version = {{ default "latest" (get $tool "version") | quote }}
{{- if $asset_pattern }}
asset_pattern = {{ $asset_pattern | quote }}
{{- end }}
{{- if $bin }}
bin = {{ $bin | quote }}
{{- end }}
{{- if $bin_path }}
bin_path = {{ $bin_path | quote }}
{{- end }}
{{- end }}
{{- end }}
